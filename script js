const chatForm = document.getElementById('chat-form');
const userInput = document.getElementById('user-input');
const chatWindow = document.getElementById('chat-window');
const heart = document.getElementById('bouncing-heart');

chatForm.addEventListener('submit', (e) => {
    e.preventDefault();
    const messageText = userInput.value.trim();

    if (messageText !== "") {
        // 1. Create the message bubble
        const msgDiv = document.createElement('div');
        msgDiv.classList.add('message', 'sent');
        msgDiv.innerHTML = `<p>${messageText}</p>`;
        chatWindow.appendChild(msgDiv);

        // 2. Trigger the Heart Bounce
        heart.classList.remove('bounce'); // Reset animation
        void heart.offsetWidth;           // Trigger reflow
        heart.classList.add('bounce');    // Start animation

        // 3. Clear input and scroll
        userInput.value = '';
        chatWindow.scrollTop = chatWindow.scrollHeight;
    }
});
