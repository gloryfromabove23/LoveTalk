<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Love Talk | Connect</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&display=swap" rel="stylesheet">
</head>
<body>

    <div class="glass-container">
        <header>
            <div class="logo-container">
                <img src="heart-logo.png" alt="Love Logo" id="bouncing-heart" class="logo-img">
                <h1>LOVE <span class="thin">TALK</span></h1>
            </div>
            <nav>
                <span class="status-dot"></span> 2,403 Online
            </nav>
        </header>

        <main id="chat-window">
            <div class="message received">
                <p>Hey! Welcome to Love Talk. Ready to meet someone new?</p>
            </div>
            </main>

        <footer>
            <form id="chat-form">
                <input type="text" id="user-input" placeholder="Type your heart out..." autocomplete="off">
                <button type="submit">Send</button>
            </form>
        </footer>
    </div>

    <script src="script.js"></script>
</body>
</html>
